msgid "Administrative abilities available to MCP clients."
msgstr "MCP クライアントから利用する管理用 Ability 群です。"

msgid "Create a new page with the provided content."
msgstr "指定された内容で固定ページを新規作成します。"

msgid "Page title."
msgstr "固定ページタイトルです。"

msgid "Page content."
msgstr "固定ページ本文です。"

msgid "Page excerpt."
msgstr "固定ページ抜粋です。"

msgid "Page status."
msgstr "固定ページステータスです。"

msgid "Created page ID."
msgstr "作成された固定ページ ID です。"

msgid "Saved page status."
msgstr "保存された固定ページステータスです。"

msgid "Admin edit link."
msgstr "管理画面の編集リンクです。"

msgid "Create a new post with the provided content."
msgstr "指定された内容で投稿を新規作成します。"

msgid "Post title."
msgstr "投稿タイトルです。"

msgid "Post content."
msgstr "投稿本文です。"

msgid "Post excerpt."
msgstr "投稿抜粋です。"

msgid "Post status."
msgstr "投稿ステータスです。"

msgid "Post type. Defaults to post."
msgstr "投稿タイプです。既定値は post です。"

msgid "Created post ID."
msgstr "作成された投稿 ID です。"

msgid "Saved post status."
msgstr "保存された投稿ステータスです。"

msgid "Update the title, content, excerpt, or status of an existing post."
msgstr "既存投稿のタイトル、本文、抜粋、ステータスを更新します。"

msgid "Post ID to update."
msgstr "更新対象の投稿 ID です。"

msgid "New post title."
msgstr "新しい投稿タイトルです。"

msgid "New post content."
msgstr "新しい投稿本文です。"

msgid "New post excerpt."
msgstr "新しい投稿抜粋です。"

msgid "New post status."
msgstr "新しい投稿ステータスです。"

msgid "Updated post ID."
msgstr "更新した投稿 ID です。"

msgid "Updated post status."
msgstr "更新後の投稿ステータスです。"

msgid "Delete an existing post or move it to the trash."
msgstr "既存投稿を削除またはゴミ箱へ移動します。"

msgid "Post ID to delete."
msgstr "削除対象の投稿 ID です。"

msgid "Permanently delete when true."
msgstr "true の場合は完全削除します。"

msgid "Post ID that was deleted."
msgstr "削除対象の投稿 ID です。"

msgid "Whether the delete operation succeeded."
msgstr "削除処理が成功したかどうかです。"

msgid "Post status before deletion."
msgstr "削除前の投稿ステータスです。"

msgid "Update the title, content, excerpt, or status of an existing page."
msgstr "既存の固定ページのタイトル、本文、抜粋、ステータスを更新します。"

msgid "Page ID to update."
msgstr "更新対象の固定ページ ID です。"

msgid "New page title."
msgstr "新しい固定ページタイトルです。"

msgid "New page content."
msgstr "新しい固定ページ本文です。"

msgid "New page excerpt."
msgstr "新しい固定ページ抜粋です。"

msgid "New page status."
msgstr "新しい固定ページステータスです。"

msgid "Updated page ID."
msgstr "更新した固定ページ ID です。"

msgid "Edit Page Blocks"
msgstr "固定ページブロック編集"

msgid "Get Page Blocks"
msgstr "固定ページブロック取得"

msgid "Edit Post Blocks"
msgstr "投稿ブロック編集"

msgid "Get Post Blocks"
msgstr "投稿ブロック取得"

msgid "Replace the block content of an existing page while keeping it editable in the block editor."
msgstr "既存の固定ページ本文を block content で置き換えつつ、ブロックエディタで再編集できる状態を保ちます。"

msgid "Retrieve the current block content of an existing page."
msgstr "既存の固定ページ本文にある現在の block content を取得します。"

msgid "Replace the block content of an existing post or custom post type entry while keeping it editable in the block editor."
msgstr "既存の投稿やカスタム投稿タイプ本文を block content で置き換えつつ、ブロックエディタで再編集できる状態を保ちます。"

msgid "Retrieve the current block content of an existing post or custom post type entry."
msgstr "既存の投稿やカスタム投稿タイプ本文にある現在の block content を取得します。"

msgid "Retrieve the current WordPress Site Health test results and supported fixes."
msgstr "現在の WordPress Site Health テスト結果と対応している修正を取得します。"

msgid "Apply a supported fix for a current WordPress Site Health issue."
msgstr "現在の WordPress Site Health 問題に対して、対応している修正を適用します。"

msgid "Page ID whose block content should be replaced."
msgstr "block content を置き換える固定ページ ID です。"

msgid "Page ID whose current block content should be retrieved."
msgstr "現在の block content を取得する固定ページ ID です。"

msgid "Post ID whose block content should be replaced."
msgstr "block content を置き換える投稿 ID です。"

msgid "Post ID whose current block content should be retrieved."
msgstr "現在の block content を取得する投稿 ID です。"

msgid "Full block markup to save into the page content."
msgstr "固定ページ本文へ保存する block markup 全文です。"

msgid "Full block markup to save into the post content."
msgstr "投稿本文へ保存する block markup 全文です。"

msgid "Requested page ID."
msgstr "取得対象の固定ページ ID です。"

msgid "Requested post ID."
msgstr "取得対象の投稿 ID です。"

msgid "Current page title."
msgstr "現在の固定ページタイトルです。"

msgid "Current post title."
msgstr "現在の投稿タイトルです。"

msgid "Current page status."
msgstr "現在の固定ページステータスです。"

msgid "Current post status."
msgstr "現在の投稿ステータスです。"

msgid "Current post type."
msgstr "現在の投稿タイプです。"

msgid "Current page block markup."
msgstr "現在の固定ページ block markup です。"

msgid "Current post block markup."
msgstr "現在の投稿 block markup です。"

msgid "Parsed block structure of the current page content."
msgstr "現在の固定ページ本文を parse_blocks した構造です。"

msgid "Parsed block structure of the current post content."
msgstr "現在の投稿本文を parse_blocks した構造です。"

msgid "Edit Page Design"
msgstr "固定ページデザイン編集"

msgid "Create or replace a page-specific block template in the active block theme."
msgstr "有効な block theme 内で、固定ページ専用の block template を作成または置換します。"

msgid "Page ID whose design should be changed."
msgstr "デザインを変更する固定ページ ID です。"

msgid "Full block template content to save for the page-specific design."
msgstr "固定ページ専用デザインとして保存する block template 全文です。"

msgid "Page ID whose design was updated."
msgstr "デザインを更新した固定ページ ID です。"

msgid "Active theme stylesheet identifier."
msgstr "現在有効なテーマの stylesheet 識別子です。"

msgid "Relative path of the saved page template file."
msgstr "保存した固定ページ template ファイルの相対パスです。"

msgid "Number of bytes written to the page template file."
msgstr "固定ページ template ファイルへ書き込んだバイト数です。"

msgid "Updated page status."
msgstr "更新後の固定ページステータスです。"

msgid "Update the site title and tagline."
msgstr "サイトタイトルとキャッチフレーズを更新します。"

msgid "New site title."
msgstr "新しいサイトタイトルです。"

msgid "New tagline."
msgstr "新しいキャッチフレーズです。"

msgid "Updated site title."
msgstr "更新後のサイトタイトルです。"

msgid "Updated tagline."
msgstr "更新後のキャッチフレーズです。"

msgid "Retrieve the audit log for ability executions."
msgstr "Ability 実行の監査ログを取得します。"

msgid "Number of entries to retrieve. Must be between 1 and 50."
msgstr "取得件数です。1 から 50 の範囲で指定します。"

msgid "Array of audit log entries."
msgstr "監査ログの配列です。"

msgid "A title is required."
msgstr "title は必須です。"

msgid "The specified post type does not exist."
msgstr "指定された投稿タイプが存在しません。"

msgid "A valid post_id is required."
msgstr "有効な post_id が必要です。"

msgid "The specified post could not be found."
msgstr "指定された投稿が見つかりません。"

msgid "Failed to delete the post."
msgstr "投稿の削除に失敗しました。"

msgid "Page design content cannot be empty."
msgstr "固定ページデザインの内容は空にできません。"

msgid "A valid page_id is required."
msgstr "有効な page_id が必要です。"

msgid "The specified page could not be found."
msgstr "指定された固定ページが見つかりません。"

msgid "Block content is required."
msgstr "block content は必須です。"

msgid "The active theme could not be loaded."
msgstr "現在有効なテーマを読み込めませんでした。"

msgid "The active theme must be a block theme to edit page design files."
msgstr "固定ページデザインファイルを編集するには、現在有効なテーマが block theme である必要があります。"

msgid "Failed to create the target directory for the page design file."
msgstr "固定ページデザインファイルの保存先ディレクトリを作成できませんでした。"

msgid "Failed to write the page design template file."
msgstr "固定ページデザイン用 template ファイルの書き込みに失敗しました。"

msgid "No settings values were provided for update."
msgstr "更新する設定値が指定されていません。"

msgid "You do not have permission to view this page."
msgstr "この画面を表示する権限がありません。"

msgid "Displays a history of operations executed through MCP clients. Up to 50 recent entries are kept."
msgstr "MCP クライアント経由で実行された操作履歴を表示します。最新 50 件まで保持します。"

msgid "Use this page to review what this plugin can do through MCP and to inspect the recent activity log in one place."
msgstr "このページでは、このプラグインが MCP 経由で実行できる内容と最近のアクティビティログを 1 か所で確認できます。"

msgid "What You Can Do"
msgstr "できること"

msgid "The plugin publishes the following administrative actions to MCP clients."
msgstr "このプラグインは、以下の管理操作を MCP クライアントに公開します。"

msgid "Create posts and pages."
msgstr "投稿と固定ページを作成できます。"

msgid "Update existing posts and pages."
msgstr "既存の投稿と固定ページを更新できます。"

msgid "Read and replace page, post, and custom post type block layouts while keeping them editable in the block editor."
msgstr "固定ページ、投稿、カスタム投稿タイプをブロックエディタで再編集できる状態のまま、block レイアウトの取得と置き換えができます。"

msgid "Change page-specific designs by editing files in the active block theme."
msgstr "有効な block theme 内のファイル編集で、固定ページごとのデザインを変更できます。"

msgid "Delete posts or move them to the trash."
msgstr "投稿を削除するかゴミ箱へ移動できます。"

msgid "Review the audit log of MCP-triggered actions."
msgstr "MCP 経由で実行された操作の監査ログを確認できます。"

msgid "Published Abilities"
msgstr "公開中の Ability"

msgid "These abilities are exposed under the wordpress-mcp-admin/* namespace."
msgstr "これらの Ability は wordpress-mcp-admin/* 名前空間で公開されています。"

msgid "Purpose"
msgstr "用途"

msgid "Required Capability"
msgstr "必要権限"

msgid "Activity Log"
msgstr "アクティビティログ"

msgid "No audit log entries yet."
msgstr "監査ログはまだありません。"

msgid "MCP Admin Tools"
msgstr "MCP Admin Tools"

msgid "Success"
msgstr "成功"

msgid "Failed"
msgstr "失敗"

msgid "Timestamp"
msgstr "日時"

msgid "Ability"
msgstr "Ability"

msgid "Result"
msgstr "結果"

msgid "Target"
msgstr "対象"

msgid "Input Summary"
msgstr "入力要約"

msgid "Error"
msgstr "エラー"

msgid "A plugin name is required."
msgstr "プラグイン名は必須です。"

msgid "A plugin with that slug already exists."
msgstr "そのスラッグのプラグインは既に存在します。"

msgid "A valid plugin identifier is required."
msgstr "有効なプラグイン識別子が必要です。"

msgid "A valid plugin slug is required."
msgstr "有効なプラグインスラッグが必要です。"

msgid "Read and update arbitrary WordPress options exposed by core or plugins."
msgstr "コアやプラグインが公開している任意の WordPress option を読み取り・更新できます。"

msgid "Inspect and update custom post type entries used by plugins for structured settings or content."
msgstr "プラグインが構造化された設定やコンテンツに使うカスタム投稿タイプ項目を確認・更新できます。"

msgid "Read and update post meta and term meta without adding plugin-specific abilities."
msgstr "プラグイン専用 Ability を追加しなくても、post meta と term meta を読み取り・更新できます。"

msgid "Configure the front page, posts page, and other reading settings."
msgstr "フロントページ、投稿ページ、その他の表示設定を構成できます。"

msgid "Inspect the current Site Health results from WordPress."
msgstr "WordPress の現在の Site Health 結果を確認できます。"

msgid "Apply selected Site Health fixes that are already available from wp-admin."
msgstr "wp-admin ですでに利用可能な Site Health 修正を適用できます。"

msgid "Import media from remote URLs, browse the media library, and assign featured images."
msgstr "リモート URL からメディアを取り込み、メディアライブラリを参照し、アイキャッチ画像を設定できます。"

msgid "Update the site logo and site icon from existing media items."
msgstr "既存のメディア項目からサイトロゴとサイトアイコンを更新できます。"

msgid "Create or update classic navigation menus and assign them to theme locations while also inspecting block navigation posts."
msgstr "クラシックナビゲーションメニューを作成・更新し、テーマロケーションへ割り当てつつ、block navigation 投稿も確認できます。"

msgid "Read theme and plugin files before updating them through MCP."
msgstr "MCP 経由で更新する前に、テーマとプラグインのファイルを読み取れます。"

msgid "Update the site title, tagline, and other selected settings."
msgstr "サイトタイトル、キャッチフレーズ、その他の選択した設定を更新できます。"

msgid "Retrieve recent items from the media library."
msgstr "メディアライブラリの最近の項目を取得します。"

msgid "Assign or clear the featured image for a post or page."
msgstr "投稿または固定ページのアイキャッチ画像を設定または解除します。"

msgid "Update the site logo and site icon using existing media library items."
msgstr "既存のメディアライブラリ項目を使ってサイトロゴとサイトアイコンを更新します。"

msgid "Update the site title, tagline, and reading settings."
msgstr "サイトタイトル、キャッチフレーズ、表示設定を更新します。"

msgid "Retrieve arbitrary WordPress option values by option name."
msgstr "option 名を指定して任意の WordPress option 値を取得します。"

msgid "Update arbitrary WordPress options by option name."
msgstr "option 名を指定して任意の WordPress option を更新します。"

msgid "Retrieve entries for an arbitrary post type, including custom post types used by plugins."
msgstr "プラグインが使うカスタム投稿タイプを含め、任意の投稿タイプの項目を取得します。"

msgid "Update a single entry from any post type, including custom post types used by plugins."
msgstr "プラグインが使うカスタム投稿タイプを含め、任意の投稿タイプの単一項目を更新します。"

msgid "Retrieve meta values for a post or term."
msgstr "投稿またはタームの meta 値を取得します。"

msgid "Update meta values for a post or term."
msgstr "投稿またはタームの meta 値を更新します。"

msgid "Retrieve forms managed by Contact Form 7 or WPForms Lite."
msgstr "Contact Form 7 または WPForms Lite が管理するフォームを取得します。"

msgid "Retrieve a single Contact Form 7 or WPForms Lite form with provider-specific configuration."
msgstr "provider ごとの設定を含む Contact Form 7 または WPForms Lite の単一フォームを取得します。"

msgid "Create or update a Contact Form 7 or WPForms Lite form through its native APIs."
msgstr "Contact Form 7 または WPForms Lite のフォームをネイティブ API 経由で作成または更新します。"

msgid "Retrieve classic navigation menus, assigned locations, and existing block navigation posts."
msgstr "クラシックナビゲーションメニュー、割り当て済みロケーション、既存の block navigation 投稿を取得します。"

msgid "Create or update a classic navigation menu, its items, and optional location assignments."
msgstr "クラシックナビゲーションメニュー、その項目、および任意のロケーション割り当てを作成または更新します。"

msgid "post-type-specific edit_posts capability"
msgstr "投稿タイプごとの edit_posts 権限"

msgid "post-type-specific edit_post capability"
msgstr "投稿タイプごとの edit_post 権限"

msgid "post/term-specific edit or manage capability"
msgstr "投稿またはタームごとの編集または管理権限"

msgid "provider-specific form view capability"
msgstr "provider ごとのフォーム閲覧権限"

msgid "provider-specific form edit capability"
msgstr "provider ごとのフォーム編集権限"

msgid "A valid relative_path inside the plugin directory is required."
msgstr "プラグインディレクトリ内の有効な relative_path が必要です。"

msgid "A valid relative_path inside the theme directory is required."
msgstr "テーマディレクトリ内の有効な relative_path が必要です。"

msgid "A valid theme slug is required."
msgstr "有効なテーマスラッグが必要です。"

msgid "A valid theme stylesheet is required."
msgstr "有効なテーマ stylesheet が必要です。"

msgid "A theme name is required."
msgstr "テーマ名は必須です。"

msgid "A theme with that slug already exists."
msgstr "そのスラッグのテーマは既に存在します。"

msgid "Activate the plugin after creation when true."
msgstr "true の場合、作成後にプラグインを有効化します。"

msgid "Activate the plugin after installation when true."
msgstr "true の場合、追加後にプラグインを有効化します。"

msgid "Activate the theme after creation when true."
msgstr "true の場合、作成後にテーマを有効化します。"

msgid "Activate the theme after installation when true."
msgstr "true の場合、追加後にテーマを有効化します。"

msgid "Activate Plugin"
msgstr "プラグイン有効化"

msgid "Activate an installed plugin."
msgstr "インストール済みプラグインを有効化します。"

msgid "Enable Plugin Auto-Update"
msgstr "プラグイン自動更新を有効化"

msgid "Enable auto-updates for an installed plugin."
msgstr "インストール済みプラグインの自動更新を有効化します。"

msgid "Admin plugin editor link when available."
msgstr "利用可能な場合の管理画面プラグインエディターリンクです。"

msgid "Admin theme editor link when available."
msgstr "利用可能な場合の管理画面テーマエディターリンクです。"

msgid "Create Page"
msgstr "固定ページ作成"

msgid "Create Plugin"
msgstr "プラグイン作成"

msgid "Create Post"
msgstr "投稿作成"

msgid "Create Theme"
msgstr "テーマ作成"

msgid "Create a new classic or block theme scaffold and optionally activate it."
msgstr "新しいクラシックテーマまたはブロックテーマの雛形を作成し、必要に応じて有効化します。"

msgid "Create a new plugin scaffold and optionally activate it."
msgstr "新しいプラグイン雛形を作成し、必要に応じて有効化します。"

msgid "Create the file when it does not already exist."
msgstr "ファイルが存在しない場合に新規作成します。"

msgid "Created plugin basename."
msgstr "作成されたプラグイン basename です。"

msgid "Created plugin display name."
msgstr "作成されたプラグイン表示名です。"

msgid "Created theme display name."
msgstr "作成されたテーマ表示名です。"

msgid "Created theme scaffold type."
msgstr "作成されたテーマ雛形タイプです。"

msgid "Created theme stylesheet identifier."
msgstr "作成されたテーマ stylesheet 識別子です。"

msgid "Created via MCP."
msgstr "MCP 経由で作成しました。"

msgid "Delete Plugin"
msgstr "プラグイン削除"

msgid "Delete Post"
msgstr "投稿削除"

msgid "Delete Theme"
msgstr "テーマ削除"

msgid "Deactivate Plugin"
msgstr "プラグイン無効化"

msgid "Deactivate an installed plugin."
msgstr "インストール済みプラグインを無効化します。"

msgid "Disable Plugin Auto-Update"
msgstr "プラグイン自動更新を無効化"

msgid "Disable auto-updates for an installed plugin."
msgstr "インストール済みプラグインの自動更新を無効化します。"

msgid "Delete an installed inactive plugin."
msgstr "インストール済みの無効なプラグインを削除します。"

msgid "Delete an installed inactive theme."
msgstr "インストール済みの無効なテーマを削除します。"

msgid "Deleted plugin basename."
msgstr "削除されたプラグイン basename です。"

msgid "Deactivated plugin basename."
msgstr "無効化したプラグイン basename です。"

msgid "Plugin basename with auto-updates enabled."
msgstr "自動更新を有効化したプラグイン basename です。"

msgid "Plugin basename with auto-updates disabled."
msgstr "自動更新を無効化したプラグイン basename です。"

msgid "Deleted theme stylesheet identifier."
msgstr "削除されたテーマ stylesheet 識別子です。"

msgid "Directory slug for the new plugin."
msgstr "新しいプラグインのディレクトリスラッグです。"

msgid "Directory slug for the new theme."
msgstr "新しいテーマのディレクトリスラッグです。"

msgid "Display name of the new plugin."
msgstr "新しいプラグインの表示名です。"

msgid "Display name of the new theme."
msgstr "新しいテーマの表示名です。"

msgid "Edit Theme"
msgstr "テーマ編集"

msgid "Edited theme stylesheet identifier."
msgstr "編集したテーマ stylesheet 識別子です。"

msgid "Failed to create a directory for the plugin scaffold."
msgstr "プラグイン雛形用のディレクトリ作成に失敗しました。"

msgid "Failed to create a directory for the theme scaffold."
msgstr "テーマ雛形用のディレクトリ作成に失敗しました。"

msgid "Failed to create the plugin directory."
msgstr "プラグインディレクトリの作成に失敗しました。"

msgid "Failed to create the target directory inside the plugin."
msgstr "プラグイン内の対象ディレクトリ作成に失敗しました。"

msgid "Failed to create the target directory inside the theme."
msgstr "テーマ内の対象ディレクトリ作成に失敗しました。"

msgid "Failed to create the theme directory."
msgstr "テーマディレクトリの作成に失敗しました。"

msgid "Failed to delete the plugin."
msgstr "プラグインの削除に失敗しました。"

msgid "Failed to delete the theme."
msgstr "テーマの削除に失敗しました。"

msgid "Failed to install the plugin."
msgstr "プラグインの追加に失敗しました。"

msgid "Failed to install the theme."
msgstr "テーマの追加に失敗しました。"

msgid "Failed to write a file in the plugin scaffold."
msgstr "プラグイン雛形内のファイル書き込みに失敗しました。"

msgid "Failed to write a file in the theme scaffold."
msgstr "テーマ雛形内のファイル書き込みに失敗しました。"

msgid "Failed to write the plugin file."
msgstr "プラグインファイルの書き込みに失敗しました。"

msgid "Failed to write the theme file."
msgstr "テーマファイルの書き込みに失敗しました。"

msgid "Full replacement file content."
msgstr "ファイル全体を置き換える内容です。"

msgid "Get Audit Log"
